const COL = {fort:"#4ade80", moyen:"#fbbf24", faible:"#f87171"};
const CBDR = {fort:"rgba(74,222,128,0.35)", moyen:"rgba(251,191,36,0.35)", faible:"rgba(248,113,113,0.35)"};

let activeFilter = 'all';
let activeSite = null;
let leafletMarkers = {};

// ── MAP INIT ─────────────────────────────────────────────────────────────────
const map = L.map('map', {
  center: [46.8050, -71.2600],
  zoom: 14,
  zoomControl: true,
  attributionControl: true
});

// Dark OSM tiles via CartoDB
L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
  attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/">CARTO</a>',
  subdomains: 'abcd',
  maxZoom: 19
}).addTo(map);

// Tramway line
L.polyline(TRAMWAY_LATLNGS, {
  color: '#6366f1',
  weight: 5,
  opacity: 0.8,
  lineCap: 'round',
  lineJoin: 'round'
}).addTo(map);

// Station markers
STATIONS.forEach(s => {
  const icon = L.divIcon({
    className: '',
    html: `<div style="width:10px;height:10px;border-radius:50%;background:#6366f1;border:3px solid rgba(99,102,241,0.35);"></div>`,
    iconSize: [10, 10],
    iconAnchor: [5, 5]
  });
  L.marker([s.lat, s.lng], {icon, interactive: true, zIndexOffset: 100})
    .bindTooltip(s.nom, {
      permanent: false,
      direction: 'top',
      offset: [0, -8],
      className: 'station-label'
    })
    .addTo(map);
});

// Rayon 400m autour de chaque station (TOD zone)
STATIONS.forEach(s => {
  L.circle([s.lat, s.lng], {
    radius: 400,
    color: 'rgba(99,102,241,0.15)',
    fillColor: 'rgba(99,102,241,0.04)',
    fillOpacity: 1,
    weight: 1,
    interactive: false
  }).addTo(map);
});

// ── SITE MARKERS ─────────────────────────────────────────────────────────────
function buildSiteMarkers() {
  Object.values(leafletMarkers).forEach(m => map.removeLayer(m));
  leafletMarkers = {};

  SITES.forEach(s => {
    const isActive = activeSite === s.id;
    const size = isActive ? 38 : 30;
    const icon = L.divIcon({
      className: '',
      html: `<div style="
        width:${size}px;height:${size}px;border-radius:50%;
        background:${CBDR[s.pot]};
        border:2px solid ${COL[s.pot]};
        display:flex;align-items:center;justify-content:center;
        font-size:11px;font-weight:600;font-family:'DM Mono',monospace;
        color:${COL[s.pot]};
        cursor:pointer;
        transition:all .2s;
        ${isActive ? `box-shadow:0 0 0 4px rgba(99,102,241,0.35);` : ''}
      ">${s.id}</div>`,
      iconSize: [size, size],
      iconAnchor: [size/2, size/2]
    });
    const m = L.marker([s.lat, s.lng], {icon, zIndexOffset: isActive ? 500 : 200});
    m.on('click', () => selectSite(s.id));
    m.bindTooltip(`<strong>${s.nom}</strong><br>Score : ${s.score} · ${s.pot.charAt(0).toUpperCase()+s.pot.slice(1)}`, {
      direction: 'top', offset: [0, -size/2], className: 'station-label'
    });
    m.addTo(map);
    leafletMarkers[s.id] = m;
  });
}

// ── LOGIC ─────────────────────────────────────────────────────────────────────
function selectSite(id) {
  activeSite = activeSite === id ? null : id;
  if (activeSite) {
    const s = SITES.find(x => x.id === id);
    map.flyTo([s.lat, s.lng], 16, {animate: true, duration: 0.8});
  }
  updateAll();
}

function getFiltered() {
  return activeFilter === 'all' ? SITES : SITES.filter(s => s.pot === activeFilter);
}

function updateStats() {
  document.getElementById('cf').textContent = SITES.filter(s => s.pot === 'fort').length;
  document.getElementById('cm').textContent = SITES.filter(s => s.pot === 'moyen').length;
  document.getElementById('ck').textContent = SITES.filter(s => s.pot === 'faible').length;
}

function updateList() {
  const filtered = getFiltered();
  const el = document.getElementById('list');
  if (!filtered.length) { el.innerHTML = '<div class="no-res">Aucun site</div>'; return; }
  el.innerHTML = filtered.map(s => `
    <div class="sitem ${activeSite === s.id ? 'on' : ''} ${s.pot}" data-id="${s.id}">
      <div class="sr1">
        <div class="snom">${s.nom}</div>
        <span class="bdg ${s.pot}">${s.pot.charAt(0).toUpperCase()+s.pot.slice(1)}</span>
      </div>
      <div class="sr2">
        <span class="ssta">${s.sta}</span>
        <span class="sdist">${s.dist} m</span>
        <div class="strack"><div class="sfill ${s.pot}" style="width:${s.score}%"></div></div>
        <span class="sval">${s.score}</span>
      </div>
    </div>`).join('');
  el.querySelectorAll('.sitem').forEach(item => {
    item.addEventListener('click', () => selectSite(parseInt(item.dataset.id)));
  });
  if (activeSite) {
    const el2 = el.querySelector(`[data-id="${activeSite}"]`);
    if (el2) el2.scrollIntoView({behavior: 'smooth', block: 'nearest'});
  }
}

function updateDetail() {
  const det = document.getElementById('det');
  const di = document.getElementById('di');
  if (!activeSite) { det.classList.remove('open'); return; }
  const s = SITES.find(x => x.id === activeSite);
  det.classList.add('open');
  const cnames = ['Proximité','Sous-util.','Bâti','Zonage','Propriét.'];
  const ckeys = ['prox','sutil','bati','zon','prop'];
  di.innerHTML = `
    <div class="dh">
      <div>
        <div class="dtitle">${s.nom}</div>
        <div class="dsub">Station ${s.sta} · ${s.dist} m · ${s.sup.toLocaleString('fr-CA')} m²</div>
      </div>
      <div><div class="sbig ${s.pot}">${s.score}</div><div class="slbl2">/ 100</div></div>
    </div>
    <div class="crit-grid">${ckeys.map((k,i) => `
      <div class="crit">
        <div class="cbar-bg"><div class="cbar" style="height:${s.cr[k]}%;background:${COL[s.pot]};opacity:.75"></div></div>
        <div class="cval">${s.cr[k]}</div>
        <div class="cname">${cnames[i]}</div>
      </div>`).join('')}</div>
    <div class="mets">
      <div class="met"><div class="mlbl">Propriétaire</div><div class="mval">${s.prop}</div></div>
      <div class="met"><div class="mlbl">Bâti</div><div class="mval">${s.bati}${s.age ? ' ('+s.age+' ans)' : ''}</div></div>
      <div class="met"><div class="mlbl">Ratio foncier</div><div class="mval">${s.ratio}</div></div>
      <div class="met"><div class="mlbl">Usage actuel</div><div class="mval">${s.usage}</div></div>
    </div>
    <div class="sh">Services applicables</div>
    <div class="tags">${s.svcs.map(t => `<span class="tag">${t}</span>`).join('')}</div>
    <div class="sh">Note d'analyse</div>
    <div class="notebox">${s.note}</div>`;
}

function updateAll() {
  updateList();
  updateDetail();
  buildSiteMarkers();
}

// Filters
document.querySelectorAll('.fbtn').forEach(btn => {
  btn.addEventListener('click', () => {
    activeFilter = btn.dataset.f;
    activeSite = null;
    document.querySelectorAll('.fbtn').forEach(b => {
      b.className = 'fbtn ' + b.dataset.f;
    });
    btn.classList.add('on');
    updateAll();
  });
});

updateStats();
buildSiteMarkers();
updateList();
